generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  CUTTING
  RECOMP
  BULKING
  MAINTENANCE
}

enum Sex {
  MALE
  FEMALE
}

enum ExerciseType {
  POLY
  ISO
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
}

model UserProfile {
  id            Int      @id @default(autoincrement())
  displayName   String?  // prénom, nom ou pseudo affiché dans l'app
  age           Int
  sex           Sex      @default(MALE)
  heightCm      Float
  currentWeight Float
  tdee          Int
  goal          Goal     @default(RECOMP)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WeightLog {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  weightKg  Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([date])
}

// Suivi journalier : pas, hydratation, notes. Une ligne par jour calendaire (UTC midnight).
model DailyLog {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique
  steps     Int      @default(0)
  waterMl   Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Exercise {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  type          ExerciseType
  dayNumber     Int           // 1, 2 ou 3
  orderIndex    Int           // ordre dans la séance
  prescription  String        // ex: "4×5-8"
  description   String?
  muscleGroups  String?
  sets          WorkoutSet[]

  @@index([dayNumber, orderIndex])
}

model WorkoutSession {
  id          Int           @id @default(autoincrement())
  date        DateTime      @default(now())
  dayNumber   Int           // 1, 2, 3
  durationMin Int?
  notes       String?
  bodyWeight  Float?
  createdAt   DateTime      @default(now())
  sets        WorkoutSet[]

  @@index([date])
}

model WorkoutSet {
  id          Int             @id @default(autoincrement())
  sessionId   Int
  exerciseId  Int
  setNumber   Int
  weightKg    Float?
  reps        Int?
  rpe         Float?
  notes       String?
  session     WorkoutSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise    Exercise        @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
}

// Catalogue d'aliments avec macros par 100g (ou par unité pour les pièces)
model Food {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  unit         String     // "g", "ml", "piece"
  unitGrams    Float?     // si unit=piece, équivalent en g (ex: 1 banane=120g)
  kcalPer100   Float
  proteinPer100 Float
  carbsPer100  Float
  fatPer100    Float
  items        MealItem[]
}

// Plan de base : conteneur des variantes de repas. Un seul plan isBase=true.
model MealPlan {
  id           Int       @id @default(autoincrement())
  label        String
  isBase       Boolean   @default(false)
  generatedAt  DateTime  @default(now())
  meals        Meal[]
}

// Une variante de repas pour un slot donné (PETIT-DÉJ / DÉJ / DÎNER).
// Plusieurs variantes par slot ; l'utilisateur en active une via UserMealPreference.
model Meal {
  id          Int                 @id @default(autoincrement())
  planId      Int
  slot        MealSlot
  variantKey  String              // "default", "skyr-avoine", "thon-pates"...
  displayName String
  description String?
  plan        MealPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)
  items       MealItem[]
  preferences UserMealPreference[]

  @@unique([planId, slot, variantKey])
  @@index([slot])
}

model MealItem {
  id        Int    @id @default(autoincrement())
  mealId    Int
  foodId    Int
  quantity  Float  // dans l'unité du Food (g, ml ou piece)
  meal      Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food      Food   @relation(fields: [foodId], references: [id])

  @@index([mealId])
}

// Sélection courante de l'utilisateur pour chaque slot.
// Une ligne max par slot (slot = clé primaire).
model UserMealPreference {
  slot      MealSlot @id
  mealId    Int
  updatedAt DateTime @updatedAt
  meal      Meal     @relation(fields: [mealId], references: [id])
}
