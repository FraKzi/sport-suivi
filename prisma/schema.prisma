generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Goal {
  CUTTING
  RECOMP
  BULKING
  MAINTENANCE
}

enum Sex {
  MALE
  FEMALE
}

enum ExerciseType {
  POLY
  ISO
}

enum ActivityLevel {
  SEDENTARY    // 1.2  — bureau, peu/pas de sport
  LIGHT        // 1.375 — 1-3 séances/semaine ou métier debout
  MODERATE     // 1.55 — 3-5 séances/semaine
  HIGH         // 1.725 — 6-7 séances/semaine ou métier physique
  VERY_HIGH    // 1.9  — sport quotidien intense + métier physique
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
}

// ============== AUTHENTIFICATION ==============

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique // case-insensitive — normalisé en lowercase à l'inscription
  passwordHash String   // bcrypt cost 10
  recoveryHash String   // bcrypt de la phrase de récupération (6 mots), affichée 1× à l'inscription
  isAdmin      Boolean  @default(false) // peut créer des codes d'invitation
  createdAt    DateTime @default(now())

  profile          UserProfile?
  weightLogs       WeightLog[]
  bodyMeasurements BodyMeasurement[]
  dailyLogs        DailyLog[]
  workoutSessions  WorkoutSession[]
  mealPlans        MealPlan[]
  mealPreferences  UserMealPreference[]
  mealConsumptions MealConsumption[]
  profileSnapshots ProfileSnapshot[]
  authSessions     AuthSession[]
  invitesCreated   InviteCode[]         @relation("InviteCreator")
  inviteUsed       InviteCode?          @relation("InviteConsumer")
}

// Session HTTP-only cookie. Le token aléatoire (32 bytes hex) est aussi l'id.
model AuthSession {
  id        String   @id // random hex token
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

// Code d'invitation à usage unique pour l'inscription.
// Créé par un admin via /admin/invites ; consommé à l'inscription.
model InviteCode {
  code        String    @id // ex: "FRK-XXXX-YYYY"
  createdById Int
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
  usedById    Int?      @unique // null = pas encore utilisé
  usedBy      User?     @relation("InviteConsumer", fields: [usedById], references: [id])
  createdAt   DateTime  @default(now())
  usedAt      DateTime?

  @@index([createdById])
}

// ============== DOMAINE (scopé par userId) ==============

model UserProfile {
  id            Int           @id @default(autoincrement())
  userId        Int           @unique // 1:1 avec User
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName   String?
  age           Int
  sex           Sex           @default(MALE)
  heightCm      Float
  currentWeight Float
  activityLevel ActivityLevel @default(MODERATE)
  tdee          Int
  goal          Goal          @default(RECOMP)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ProfileSnapshot {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime      @default(now())
  age           Int
  sex           Sex
  heightCm      Float
  weightKg      Float
  activityLevel ActivityLevel
  tdee          Int
  goal          Goal

  @@index([userId, date])
  @@index([date])
}

model WeightLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  weightKg  Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([date])
}

model BodyMeasurement {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @default(now())
  waistCm    Float?
  hipCm      Float?
  neckCm     Float?
  chestCm    Float?
  armCm      Float?
  thighCm    Float?
  bodyFatPct Float?
  notes      String?
  createdAt  DateTime @default(now())

  @@index([userId, date])
  @@index([date])
}

// Une ligne par jour calendaire (UTC midnight) PAR utilisateur.
model DailyLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  steps     Int      @default(0)
  waterMl   Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
}

// Catalogue d'exercices partagé entre utilisateurs.
model Exercise {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  type         ExerciseType
  dayNumber    Int
  orderIndex   Int
  prescription String
  description  String?
  muscleGroups String?
  archived     Boolean      @default(false)
  sets         WorkoutSet[]

  @@index([dayNumber, orderIndex])
  @@index([archived])
}

model WorkoutSession {
  id          Int          @id @default(autoincrement())
  userId      Int
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime     @default(now())
  dayNumber   Int
  durationMin Int?
  notes       String?
  bodyWeight  Float?
  createdAt   DateTime     @default(now())
  sets        WorkoutSet[]

  @@index([userId, date])
  @@index([date])
}

model WorkoutSet {
  id         Int            @id @default(autoincrement())
  sessionId  Int
  exerciseId Int
  setNumber  Int
  weightKg   Float?
  reps       Int?
  rpe        Float?
  notes      String?
  session    WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
}

// Catalogue d'aliments partagé.
model Food {
  id            Int        @id @default(autoincrement())
  name          String     @unique
  unit          String
  unitGrams     Float?
  kcalPer100    Float
  proteinPer100 Float
  carbsPer100   Float
  fatPer100     Float
  items         MealItem[]
}

// Plan alimentaire par utilisateur (chaque user a son propre plan isBase=true).
model MealPlan {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  isBase      Boolean  @default(false)
  generatedAt DateTime @default(now())
  meals       Meal[]

  @@index([userId, isBase])
}

model Meal {
  id           Int                  @id @default(autoincrement())
  planId       Int
  slot         MealSlot
  variantKey   String
  displayName  String
  description  String?
  plan         MealPlan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  items        MealItem[]
  preferences  UserMealPreference[]
  consumptions MealConsumption[]

  @@unique([planId, slot, variantKey])
  @@index([slot])
}

model MealConsumption {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  slot      MealSlot
  mealId    Int
  meal      Meal     @relation(fields: [mealId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, date, slot])
  @@index([userId, date])
  @@index([date])
}

model MealItem {
  id       Int   @id @default(autoincrement())
  mealId   Int
  foodId   Int
  quantity Float
  meal     Meal  @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food     Food  @relation(fields: [foodId], references: [id])

  @@index([mealId])
}

// Variante active par slot, pour un user donné.
model UserMealPreference {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot      MealSlot
  mealId    Int
  updatedAt DateTime @updatedAt
  meal      Meal     @relation(fields: [mealId], references: [id])

  @@unique([userId, slot])
}
